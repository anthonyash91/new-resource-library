NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000
SUPABASE_SERVICE_ROLE_KEY=

# Production: require search/facets RPCs (no full-table Node fallback). Default on when NODE_ENV=production.
# SEARCH_REQUIRE_RPC=true

# Optional: shared API rate limiting across Vercel instances (Upstash Redis).
# Without these, middleware uses in-memory limits per instance.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
